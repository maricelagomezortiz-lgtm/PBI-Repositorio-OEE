                "    Source = Sql.Database(\"DESKTOP-8JHGPSS\", \"EstampadoAutomotriz\", [Query=\"select ot.fecha,ot.id_orden, op.secuencia,ct.nombre as ct,art.nombre as np, art.tipo,#(lf)rep.cantidad_producida,(rep.tiempo_real_horas / op.tiempo_std_pza) as qstrd, rep.piezas_malas,rep.causa_scrap,#(lf)rep.tiempo_real_horas, (rep.cantidad_producida * op.tiempo_std_pza) as tstd,rep.tiempo_muerto_horas, causa_tiempo_muerto#(lf)#(lf)from #(lf)reporte_tiempos rep#(lf)left join ordenes_produccion ot on rep.id_orden = ot.id_orden#(lf)left join operaciones op on rep.id_operacion = op.id_operacion#(lf)left join centros_trabajo ct on op.id_centro = ct.id_centro#(lf)left join rutas on op.id_ruta = rutas.id_ruta#(lf)left join articulos art on rutas.id_articulo = art.id_articulo#(lf)order by 1,2#(lf)#(lf)#(lf)#(lf)\"])",
                "in",
                "    Source"
              ],
              "type": "m"
            }
          }
        ]
      },
